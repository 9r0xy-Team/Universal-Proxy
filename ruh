<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Universal Proxy · Universal Proxy</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
  background: linear-gradient(135deg, #0b0e14, #141a24);
  color: #d1d5db;
  min-height: 100vh;
  display: flex; flex-direction: column;
  user-select: none;
}
header {
  background: #151c25;
  padding: 1rem 2rem;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 2px solid #3b82f6;
  position: sticky;
  top: 0;
  z-index: 100;
}
header h1 {
  font-size: 1.5rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: #e0e7ff;
  user-select: text;
}
header h1 span { color: #3b82f6; }
nav a {
  color: #9ca3af;
  text-decoration: none;
  margin-left: 1.5rem;
  font-size: 1rem;
  font-weight: 600;
  transition: color 0.3s ease;
  user-select: text;
}
nav a:hover {
  color: #3b82f6;
}
.container {
  flex: 1;
  padding: 1.5rem 2rem;
  max-width: 1400px;
  margin: 0 auto;
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.card {
  background: rgba(31, 41, 55, 0.9);
  backdrop-filter: blur(6px);
  border-radius: 14px;
  padding: 1.5rem 2rem;
  border: 1px solid #374151;
  box-shadow: 0 8px 16px rgba(0,0,0,0.5);
  transition: background 0.3s ease, box-shadow 0.3s ease;
}
.card:hover {
  background: rgba(31, 41, 55, 0.95);
  box-shadow: 0 12px 24px rgba(0,0,0,0.7);
}
.card-title {
  font-size: 1.15rem;
  font-weight: 700;
  margin-bottom: 1rem;
  color: #e5e7eb;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.input-group {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.input-group input {
  flex: 1;
  min-width: 220px;
  padding: 0.8rem 1.2rem;
  border: 2px solid #4b5563;
  border-radius: 10px;
  background: #111827;
  color: #e5e7eb;
  font-size: 1rem;
  outline: none;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
  user-select: text;
}
.input-group input:focus {
  border-color: #3b82f6;
  box-shadow: 0 0 8px rgba(59,130,246,0.6);
}
.input-group input::placeholder {
  color: #6b7280;
}
.input-group input.valid {
  border-color: #22c55e;
}
.input-group input.invalid {
  border-color: #ef4444;
}
.input-group button {
  padding: 0.8rem 2rem;
  background: #3b82f6;
  color: #fff;
  border: none;
  border-radius: 10px;
  font-weight: 800;
  cursor: pointer;
  transition: background 0.3s ease, transform 0.15s ease;
  user-select: none;
}
.input-group button:hover:not(:disabled) {
  background: #2563eb;
  transform: scale(1.05);
}
.input-group button:disabled {
  background: #4b5563;
  cursor: not-allowed;
  transform: none;
}
#feedback {
  font-size: 0.9rem;
  margin-top: 0.5rem;
  min-height: 1.3em;
  font-weight: 600;
  user-select: none;
}
#feedback.valid { color: #22c55e; }
#feedback.info { color: #3b82f6; }
#feedback.error { color: #ef4444; }
.stats-row {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: space-between;
}
.stat-item {
  background: #111827;
  padding: 0.8rem 1.2rem;
  border-radius: 10px;
  border: 1px solid #374151;
  flex: 1;
  min-width: 110px;
  text-align: center;
  transition: background 0.3s ease;
  user-select: none;
}
.stat-item:hover {
  background: #1f2937;
}
.stat-item .value {
  font-size: 1.8rem;
  font-weight: 900;
  color: #3b82f6;
  letter-spacing: 0.05em;
}
.stat-item .label {
  font-size: 0.75rem;
  color: #9ca3af;
  margin-top: 0.3rem;
  text-transform: uppercase;
  letter-spacing: 0.6px;
}
.settings-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 1.25rem;
}
.setting-item {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  user-select: none;
}
.setting-item label {
  font-size: 0.85rem;
  color: #9ca3af;
  font-weight: 600;
}
.setting-item input,
.setting-item select {
  padding: 0.6rem;
  border: 1px solid #4b5563;
  border-radius: 8px;
  background: #111827;
  color: #e5e7eb;
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.3s ease;
}
.setting-item input:focus,
.setting-item select:focus {
  border-color: #3b82f6;
  box-shadow: 0 0 8px rgba(59,130,246,0.5);
}
.setting-item button,
.setting-item .action-btn {
  padding: 0.6rem 1rem;
  background: #374151;
  color: #e5e7eb;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 700;
  transition: background 0.3s ease;
  user-select: none;
}
.setting-item button:hover,
.setting-item .action-btn:hover {
  background: #4b5563;
}
.logs-box {
  background: #0f172a;
  border: 1px solid #1e293b;
  border-radius: 8px;
  padding: 0.8rem 1rem;
  max-height: 140px;
  overflow-y: auto;
  font-family: 'Cascadia Code', 'Fira Code', monospace;
  font-size: 0.8rem;
  color: #94a3b8;
  user-select: text;
}
.logs-box .log-entry {
  margin-bottom: 0.25rem;
  padding: 0.15rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.iframe-wrapper {
  width: 100%;
  height: 70vh;
  border: 1px solid #374151;
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  background: #111827;
  box-shadow: inset 0 0 32px rgba(0,0,0,0.7);
}
iframe {
  width: 100%;
  height: 100%;
  border: none;
}
.loading-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(17,24,39,0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #3b82f6;
  font-size: 1.4rem;
  z-index: 20;
  flex-direction: column;
  gap: 1rem;
  user-select: none;
  display: none;
}
.loading-overlay .spinner {
  width: 48px;
  height: 48px;
  border: 5px solid #374151;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.75s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.footer {
  background: #151c25;
  padding: 1rem 2rem;
  text-align: center;
  border-top: 1px solid #2a3744;
  font-size: 0.85rem;
  color: #6b7280;
  user-select: none;
}
.advanced-toggle {
  display: flex;
  gap: 0.6rem;
  align-items: center;
  cursor: pointer;
  margin-top: 0.6rem;
  user-select: none;
}
.advanced-toggle input[type="checkbox"] {
  width: auto;
  cursor: pointer;
}
.hidden-panel {
  display: none;
}
.hidden-panel.show {
  display: block;
}
@media (max-width: 768px) {
  header {
    flex-direction: column;
    gap: 0.5rem;
  }
  nav a {
    margin-left: 0;
    font-size: 1rem;
  }
  .input-group {
    flex-direction: column;
  }
  .input-group button {
    width: 100%;
  }
  .stats-row {
    flex-direction: column;
    gap: 1rem;
  }
  .stat-item {
    min-width: auto;
  }
  .settings-grid {
    grid-template-columns: 1fr;
  }
}
</style>
</head>
<body>

<header>
  <h1><span>🛡️</span> Universal Proxy</h1>
  <nav>
    <a href="#" tabindex="1">Dashboard</a>
    <a href="#" tabindex="2">Logs</a>
    <a href="#" tabindex="3">Pro Tools</a>
  </nav>
</header>

<div class="container" role="main" aria-label="Proxy Interface">
  <!-- Main input -->
    <section class="card" aria-labelledby="input-title">
    <h2 id="input-title" class="card-title">🌐 Enter any URL</h2>
    <div class="input-group">
      <input type="url" id="urlInput" placeholder="https://google.com" autocomplete="off" aria-describedby="feedback" aria-required="true" />
      <button id="goBtn" aria-label="Load URL" disabled>Go</button>
    </div>
    <div id="feedback" role="alert" aria-live="polite"></div>
    <div class="advanced-toggle">
      <label for="toggleAdvanced">☰ Advanced options</label>
      <input type="checkbox" id="toggleAdvanced" aria-controls="advancedPanel" aria-expanded="false" />
    </div>
  </section>

  <!-- Advanced panel (hidden) -->
  <section id="advancedPanel" class="card hidden-panel" aria-labelledby="advanced-title" tabindex="-1">
    <h2 id="advanced-title" class="card-title">⚙️ Advanced Settings</h2>
    <div class="settings-grid">
      <div class="setting-item">
        <label for="rateLimit">Rate limit (req/min)</label>
        <input type="number" id="rateLimit" value="20" min="1" max="200" />
      </div>
      <div class="setting-item">
        <label for="cacheTtl">Cache TTL (seconds)</label>
        <input type="number" id="cacheTtl" value="30" min="0" max="600" />
      </div>
      <div class="setting-item">
        <label for="userAgent">User‑Agent rotation</label>
        <select id="userAgent" aria-describedby="userAgentDesc">
          <option value="random">Random</option>
          <option value="Mozilla/5.0 (Windows NT 10.0; Win64; x64)">Windows Chrome</option>
          <option value="Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7)">Mac Safari</option>
          <option value="Mozilla/5.0 (X11; Linux x86_64)">Linux Firefox</option>
        </select>
        <small id="userAgentDesc" style="color:#6b7280;">Select user agent to rotate for requests.</small>
      </div>
      <div class="setting-item">
        <label for="weeblyOnly">Weebly‑only mode</label>
        <select id="weeblyOnly">
          <option value="no">No (all URLs)</option>
          <option value="yes">Yes (trusted)</option>
        </select>
      </div>
      <div class="setting-item">
        <label for="proxyApi">Fallback proxy API</label>
        <select id="proxyApi">
          <option value="allorigins">api.allorigins.win</option>
          <option value="corsproxy">corsproxy.io</option>
          <option value="thingproxy">thingproxy.freeboard.io</option>
        </select>
      </div>
      <div class="setting-item" style="grid-column: span 2; display: flex; gap: 0.5rem; justify-content: flex-end;">
        <button id="applySettings">Apply</button>
        <button id="clearCache">Clear cache</button>
        <button id="downloadPage">Download current page</button>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="card" aria-label="Live Performance Stats">
    <h2 class="card-title">📊 Live Performance</h2>
    <div class="stats-row" role="list">
      <div class="stat-item" role="listitem" tabindex="0"><div class="value" id="statRequests">0</div><div class="label">Requests</div></div>
      <div class="stat-item" role="listitem" tabindex="0"><div class="value" id="statCache">0</div><div class="label">Cache hits</div></div>
      <div class="stat-item" role="listitem" tabindex="0"><div class="value" id="statBlocked">0</div><div class="label">Blocked</div></div>
      <div class="stat-item" role="listitem" tabindex="0"><div class="value" id="statSpeed">0ms</div><div class="label">Avg latency</div></div>
      <div class="stat-item" role="listitem" tabindex="0"><div class="value" id="statUptime">100%</div><div class="label">Uptime (simulated)</div></div>
    </div>
  </section>

  <!-- Logs -->
  <section class="card" aria-label="Request Log">
    <h2 class="card-title">📜 Request Log <small style="font-size:0.7rem;color:#6b7280;">(last 100)</small></h2>
    <div class="logs-box" id="logsContainer" tabindex="0" aria-live="polite" aria-relevant="additions"></div>
  </section>

  <!-- Iframe -->
  <section class="card" aria-label="Preview">
    <h2 class="card-title">🔍 Preview</h2>
    <div class="iframe-wrapper">
      <div class="loading-overlay" id="loadingOverlay" aria-live="assertive" aria-atomic="true" role="alert">
        <div class="spinner" aria-hidden="true"></div>
        <span>Loading site …</span>
      </div>
      <iframe id="proxyFrame" sandbox="allow-scripts allow-same-origin allow-forms allow-popups" title="Proxied site preview"></iframe>
    </div>
  </section>
</div>

<footer class="footer" role="contentinfo">Universal Proxy · Universal Proxy v3.0 · Works with any URL</footer>

<script>
const state = {
  requests: 0,
  cacheHits: 0,
  blocked: 0,
  totalTime: 0,
  avgTime: 0,
  timestamps: [],
  uptime: 100
};

let settings = {
  rateLimit: 20,
  cacheTtl: 30,
  userAgent: 'random',
  weeblyOnly: false,
  proxyApi: 'allorigins'
};

const cache = new Map();

const urlInput = document.getElementById('urlInput');
const goBtn = document.getElementById('goBtn');
const feedback = document.getElementById('feedback');
const iframe = document.getElementById('proxyFrame');
const loadingOverlay = document.getElementById('loadingOverlay');
const logsContainer = document.getElementById('logsContainer');
const advancedPanel = document.getElementById('advancedPanel');
const toggleAdvanced = document.getElementById('toggleAdvanced');

const statRequests = document.getElementById('statRequests');
const statCache = document.getElementById('statCache');
const statBlocked = document.getElementById('statBlocked');
const statSpeed = document.getElementById('statSpeed');
const statUptime = document.getElementById('statUptime');

function addLog(msg, level = 'info') {
  const color = level === 'error' ? '#ef4444' : level === 'warn' ? '#f59e0b' : level === 'success' ? '#22c55e' : '#94a3b8';
  const time = new Date().toLocaleTimeString();
  const entry = document.createElement('div');
  entry.className = 'log-entry';
  entry.style.color = color;
  entry.textContent = `[${time}][${level.toUpperCase()}] ${msg}`;
  logsContainer.appendChild(entry);
  logsContainer.scrollTop = logsContainer.scrollHeight;
  if (logsContainer.children.length > 100) logsContainer.removeChild(logsContainer.firstChild);
}

function updateStats() {
  statRequests.textContent = state.requests;
  statCache.textContent = state.cacheHits;
  statBlocked.textContent = state.blocked;
  statSpeed.textContent = state.avgTime + 'ms';
  statUptime.textContent = state.uptime + '%';
}

function isValidURL(s) {
  try { const u = new URL(s); return u.protocol === 'http:' || u.protocol === 'https:'; }
  catch { return false; }
}

function buildProxyUrl(target) {
  const api = settings.proxyApi;
  let base = '';
  if (api === 'allorigins') base = 'https://api.allorigins.win/raw?url=';
  else if (api === 'corsproxy') base = 'https://corsproxy.io/?' + encodeURIComponent(target);
  else if (api === 'thingproxy') base = 'https://thingproxy.freeboard.io/fetch/' + encodeURIComponent(target);
  else base = `https://api.allorigins.win/raw?url=`;
  return base + encodeURIComponent(target);
}

function rewriteHtml(html, baseUrl) {
  html = html.replace(/<script[^>]*>.*?window\.top\.location.*?<\/script>/gis, '');
  html = html.replace(/<meta[^>]*http-equiv=["']refresh["'][^>]*>/gi, '');
  html = html.replace(/(src|href|action)=(["'])((?:https?:)?\/\/[^"'\s]+|(?:\/[^"'\s]*))\2/gi, (match, attr, quote, url) => {
    let absolute;
    try { absolute = new URL(url, baseUrl).href; } catch { return match; }
    if (settings.weeblyOnly) {
      const host = new URL(absolute).hostname;
      if (!host.endsWith('.weebly.com') && host !== 'weebly.com') return match;
    }
    const proxied = buildProxyUrl(absolute);
    return `${attr}=${quote}${proxied}${quote}`;
  });
  html = html.replace(/<form\s/gi, '<form target="_blank" ');
  return html;
}

async function loadProxy(target) {
  const now = Date.now();
  state.timestamps = state.timestamps.filter(t => now - t < 60000);
  if (state.timestamps.length >= settings.rateLimit) {
    feedback.textContent = '⚠ Rate limit exceeded. Wait a moment.';
    feedback.className = 'error';
    state.blocked++;
    updateStats();
    addLog(`Rate limit blocked: ${target}`, 'warn');
    loadingOverlay.style.display = 'none';
    return;
  }
  state.timestamps.push(now);
  const cached = cache.get(target);
  if (cached && (now - cached.time < settings.cacheTtl * 1000)) {
    state.cacheHits++;
    updateStats();
    addLog(`Cache hit: ${target}`, 'success');
    const blob = new Blob([cached.html], { type: 'text/html' });
    iframe.src = URL.createObjectURL(blob);
    loadingOverlay.style.display = 'none';
    feedback.textContent = 'Loaded from cache ✓';
    feedback.className = 'valid';
    return;
  }
  loadingOverlay.style.display = 'flex';
  feedback.textContent = 'Fetching …';
  feedback.className = 'info';
  const startTime = performance.now();
  try {
    const proxyUrl = buildProxyUrl(target);
    const resp = await fetch(proxyUrl);
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    let html = await resp.text();
    const contentType = resp.headers.get('content-type') || '';
    if (contentType.includes('text/html')) {
      html = rewriteHtml(html, target);
    }
    cache.set(target, { html, time: Date.now() });
    const blob = new Blob([html], { type: 'text/html' });
    iframe.src = URL.createObjectURL(blob);
    const elapsed = Math.round(performance.now() - startTime);
    state.totalTime += elapsed;
    state.requests++;
    state.avgTime = state.requests ? Math.round(state.totalTime / state.requests) : 0;
    updateStats();
    addLog(`Loaded: ${target} (${elapsed}ms)`, 'success');
    feedback.textContent = `Loaded in ${elapsed}ms ✓`;
    feedback.className = 'valid';
  } catch (err) {
    feedback.textContent = `✗ Failed: ${err.message}`;
    feedback.className = 'error';
    addLog(`Error loading ${target}: ${err.message}`, 'error');
    state.blocked++;
    updateStats();
    if (settings.proxyApi !== 'thingproxy') {
      const fallback = settings.proxyApi === 'allorigins' ? 'corsproxy' : 'thingproxy';
      addLog(`Trying fallback proxy: ${fallback}`, 'warn');
      settings.proxyApi = fallback;
      setTimeout(() => loadProxy(target), 300);
    }
  } finally {
    loadingOverlay.style.display = 'none';
  }
}

urlInput.addEventListener('input', () => {
  const val = urlInput.value.trim();
  if (!val) {
    feedback.textContent = '';
    urlInput.classList.remove('valid', 'invalid');
    goBtn.disabled = true;
    return;
  }
  if (isValidURL(val)) {
    feedback.textContent = '✓ Valid URL';
    feedback.className = 'valid';
    urlInput.classList.add('valid'); urlInput.classList.remove('invalid');
    goBtn.disabled = false;
  } else {
    feedback.textContent = '✗ Invalid URL (needs http:// or https://)';
    feedback.className = 'error';
    urlInput.classList.add('invalid'); urlInput.classList.remove('valid');
    goBtn.disabled = true;
  }
});

goBtn.addEventListener('click', () => {
  const target = urlInput.value.trim();
  if (!isValidURL(target)) return;
  iframe.src = 'about:blank';
  setTimeout(() => loadProxy(target), 100);
});

urlInput.addEventListener('keydown', e => { if (e.key === 'Enter') goBtn.click(); });

toggleAdvanced.addEventListener('change', () => {
  advancedPanel.classList.toggle('show', toggleAdvanced.checked);
  toggleAdvanced.setAttribute('aria-expanded', toggleAdvanced.checked);
  if(toggleAdvanced.checked) advancedPanel.focus();
});

document.getElementById('applySettings').addEventListener('click', () => {
  settings.rateLimit = parseInt(document.getElementById('rateLimit').value) || 20;
  settings.cacheTtl = parseInt(document.getElementById('cacheTtl').value) || 30;
  settings.userAgent = document.getElementById('userAgent').value;
  settings.weeblyOnly = document.getElementById('weeblyOnly').value === 'yes';
  settings.proxyApi = document.getElementById('proxyApi').value;
  addLog(`Settings updated: rate=${settings.rateLimit}, cache=${settings.cacheTtl}s, weeblyOnly=${settings.weeblyOnly}, proxy=${settings.proxyApi}`, 'warn');
});

document.getElementById('clearCache').addEventListener('click', () => {
  cache.clear();
  addLog('Cache cleared', 'warn');
});

document.getElementById('downloadPage').addEventListener('click', () => {
  const lastUrl = urlInput.value.trim();
  if (!lastUrl) { addLog('No page loaded yet', 'error'); return; }
  const cached = cache.get(lastUrl);
  if (!cached) { addLog('Page not in cache, reload first', 'error'); return; }
  const blob = new Blob([cached.html], { type: 'text/html' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'proxied-page.html';
  a.click();
  URL.revokeObjectURL(a.href);
  addLog('Page downloaded', 'success');
});

iframe.src = 'about:blank';
const defaultUrl = 'https://google.com';
urlInput.value = defaultUrl;
addLog('Universal Proxy ready – loading Google by default', 'info');
setTimeout(() => loadProxy(defaultUrl), 300);
</script>
</body>
</html>
