// ===== CLOAK FUNCTIONALITY =====
function toggleCloak() {
  state.isCloaked = !state.isCloaked;
  if (state.isCloaked) {
    cloakOverlay.classList.add('active');
    document.body.classList.add('cloaked');
    cloakBtn.textContent = '👁️ Uncloak';
    cloakBtn.classList.add('uncloak');
    addLog('🔒 Cloaked - Press Ctrl+Shift+C to uncloak', 'success');
  } else {
    cloakOverlay.classList.remove('active');
    document.body.classList.remove('cloaked');
    cloakBtn.textContent = '🔒 Cloak Tab';
    cloakBtn.classList.remove('uncloak');
    addLog('👁️ Uncloaked', 'info');
  }
}

cloakBtn.addEventListener('click', toggleCloak);
document.addEventListener('keydown', (e) => {
  if (e.ctrlKey && e.shiftKey && e.code === 'KeyC') {
    e.preventDefault();
    toggleCloak();
  }
});

