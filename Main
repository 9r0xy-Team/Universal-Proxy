  settings.proxyMethod = document.getElementById('proxyMethod').value;
  settings.proxyApi = document.getElementById('proxyApi').value;
  settings.fallbackApi = document.getElementById('fallbackApi').value;
  settings.userAgent = document.getElementById('userAgent').value;
  settings.linkRewrite = document.getElementById('linkRewrite').value;
  settings.timeout = parseInt(document.getElementById('timeout').value);
  addLog('✅ Settings applied', 'success');
});

document.getElementById('clearCache')?.addEventListener('click', () => {
  cache.clear();
  state.cacheHits = 0;
  updateStats();
  addLog('🗑️ Cache cleared', 'success');
});

document.getElementById('testProxy')?.addEventListener('click', () => {
  testAllProxies();
});

// Initialize
updateStats();
testAllProxies();
</script>

</body>
</html>
