        <button id="downloadLogs" style="padding: 0.6rem 1rem; background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; margin-left: 0.5rem;">Download Logs</button>
