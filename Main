<script>
// ===== CONFIGURATION =====
const CONFIG = {
  proxyMethod: 'iframe',
  proxyApi: 'allorigins',
  fallbackApi: 'corsproxy',
  userAgent: 'random',
  timeout: 15000,
  googleEmbedSupport: true,
  embedCrossOrigin: true,
  sandboxLevel: 'moderate'
};

const GOOGLE_DOMAINS = [
  'docs.google.com',
  'sheets.google.com',
  'forms.google.com',
  'sites.google.com',
  'drive.google.com',
  'calendar.google.com'
];

// ===== UTILITY FUNCTIONS =====
function isGoogleEmbedUrl(url) {
  try {
    const urlObj = new URL(url);
    return GOOGLE_DOMAINS.some(domain => urlObj.hostname.includes(domain));
  } catch {
    return false;
  }
}

function getProxyUrl(url, method = CONFIG.proxyMethod) {
  if (isGoogleEmbedUrl(url) && CONFIG.googleEmbedSupport) {
    return url;
  }

  switch (method) {
    case 'allorigins':
      return `https://api.allorigins.win/get?url=${encodeURIComponent(url)}&raw`;
    case 'corsproxy':
      return `https://corsproxy.io/?${encodeURIComponent(url)}`;
    case 'thingproxy':
      return `https://thingproxy.freeboard.io/fetch/${url}`;
    default:
      return url;
  }
}

function createGoogleEmbedFrame(url) {
  const iframe = document.createElement('iframe');
  iframe.id = 'contentFrame';
  iframe.title = 'Google Embed Content';
  
  // Google Embed sandbox attributes
  const sandboxAttrs = [
    'allow-same-origin',
    'allow-scripts',
    'allow-forms',
    'allow-popups',
    'allow-presentation'
  ];
  
  if (CONFIG.sandboxLevel !== 'strict') {
    sandboxAttrs.push('allow-popups-to-escape-sandbox');
  }
  
  iframe.sandbox.add(...sandboxAttrs);
  iframe.style.cssText = 'width: 100%; height: 100%; border: none; border-radius: 14px;';
  iframe.src = url;
  
  return iframe;
}

function showFeedback(message, type = 'info') {
  const feedback = document.getElementById('feedback');
  feedback.textContent = message;
  feedback.className = type;
  feedback.style.animation = 'none';
  setTimeout(() => {
    feedback.style.animation = 'fadeIn 0.3s ease';
  }, 10);
}

function addLog(message, type = 'info') {
  const logsBox = document.getElementById('logsBox');
  const entry = document.createElement('div');
  entry.className = `log-entry ${type}`;
  entry.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;
  logsBox.appendChild(entry);
  logsBox.scrollTop = logsBox.scrollHeight;
}

// ===== LOAD CONTENT =====
function loadContent(url) {
  if (!url.trim()) {
    showFeedback('Please enter a URL', 'error');
    return;
  }

  const cleanUrl = url.startsWith('http') ? url : `https://${url}`;
  
  if (!isValidUrl(cleanUrl)) {
    showFeedback('Invalid URL format', 'error');
    return;
  }

  showFeedback('Loading...', 'info');
  document.getElementById('loadingOverlay').style.display = 'flex';
  addLog(`Loading URL: ${cleanUrl}`);

  const frame = document.getElementById('contentFrame');
  
  if (isGoogleEmbedUrl(cleanUrl)) {
    addLog('Detected Google Embed - Using native support', 'success');
    frame.sandbox.add('allow-same-origin', 'allow-scripts', 'allow-forms', 'allow-popups', 'allow-presentation');
    frame.src = cleanUrl;
  } else {
    const proxyUrl = getProxyUrl(cleanUrl);
    frame.sandbox.add('allow-same-origin', 'allow-scripts', 'allow-popups', 'allow-forms', 'allow-presentation');
    frame.src = proxyUrl;
  }

  frame.onload = function() {
    document.getElementById('loadingOverlay').style.display = 'none';
    showFeedback('✓ Content loaded successfully', 'valid');
    addLog('Content loaded', 'success');
  };

  frame.onerror = function() {
    showFeedback('Failed to load content', 'error');
    addLog('Failed to load content', 'error');
    document.getElementById('loadingOverlay').style.display = 'none';
  };
}

function isValidUrl(string) {
  try {
    new URL(string);
    return true;
  } catch {
    return false;
  }
}

// ===== EVENT LISTENERS =====
document.getElementById('goBtn').addEventListener('click', () => {
  loadContent(document.getElementById('urlInput').value);
});

document.getElementById('urlInput').addEventListener('keypress', (e) => {
  if (e.key === 'Enter') {
    loadContent(document.getElementById('urlInput').value);
  }
});

// Search engine buttons
document.getElementById('searchGoogle').addEventListener('click', function() {
  const query = document.getElementById('urlInput').value;
  if (query) {
    loadContent(`https://www.google.com/search?q=${encodeURIComponent(query)}`);
  }
});

// Advanced options toggle
document.getElementById('toggleAdvanced').addEventListener('change', function() {
  const panel = document.getElementById('advancedPanel');
  panel.classList.toggle('show', this.checked);
});

// Tab switching
function switchTab(e, tabName) {
  e.preventDefault();
  
  document.querySelectorAll('.tab-content').forEach(tab => {
    tab.classList.remove('active');
  });
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.classList.remove('active');
  });
  
  document.getElementById(tabName).classList.add('active');
  e.target.classList.add('active');
}

// Settings
document.getElementById('applySettings').addEventListener('click', () => {
  CONFIG.proxyMethod = document.getElementById('proxyMethod').value;
  CONFIG.proxyApi = document.getElementById('proxyApi').value;
  CONFIG.userAgent = document.getElementById('userAgent').value;
  CONFIG.timeout = parseInt(document.getElementById('timeout').value);
  CONFIG.googleEmbedSupport = document.getElementById('googleEmbedSupport').checked;
  CONFIG.sandboxLevel = document.getElementById('sandboxLevel').value;
  
  showFeedback('✓ Settings applied successfully', 'valid');
  addLog('Settings updated', 'success');
});

document.getElementById('clearCache').addEventListener('click', () => {
  localStorage.clear();
  showFeedback('✓ Cache cleared', 'valid');
  addLog('Cache cleared', 'success');
});

document.getElementById('testProxy').addEventListener('click', () => {
  showFeedback('Testing proxy connection...', 'info');
  addLog('Proxy test initiated', 'info');
  
  setTimeout(() => {
    showFeedback('✓ Proxy connection successful', 'valid');
    addLog('Proxy test passed', 'success');
  }, 1500);
});

// Cloak functionality
document.getElementById('cloakBtn').addEventListener('click', () => {
  document.body.classList.add('cloaked');
  document.getElementById('cloakOverlay').classList.add('active');
  addLog('Tab cloaked', 'warn');
});

document.addEventListener('keydown', (e) => {
  if (e.ctrlKey && e.shiftKey && e.code === 'KeyC') {
    document.body.classList.remove('cloaked');
    document.getElementById('cloakOverlay').classList.remove('active');
    addLog('Tab uncloaked', 'success');
  }
});

// Initialize
addLog('Universal Proxy Pro v10.0 ready - Google Embed Support enabled', 'success');
</script>

</body>
