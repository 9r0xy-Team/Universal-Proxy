<script>
// ---------- STATE ----------
const state = {
requests: 0,
cacheHits: 0,
blocked: 0,
totalTime: 0,
avgTime: 0,
timestamps: [],
uptime: 100
};

let settings = {
rateLimit: 20,
cacheTtl: 30,
userAgent: 'random',
weeblyOnly: false, // Default: allow all URLs
proxyApi: 'allorigins'
};

const cache = new Map();

// DOM refs
const urlInput = document.getElementById('urlInput');
const goBtn = document.getElementById('goBtn');
const feedback = document.getElementById('feedback');
const iframe = document.getElementById('proxyFrame');
const loadingOverlay = document.getElementById('loadingOverlay');
const logsContainer = document.getElementById('logsContainer');
const advancedPanel = document.getElementById('advancedPanel');
const toggleAdvanced = document.getElementById('toggleAdvanced');

const statRequests = document.getElementById('statRequests');
const statCache = document.getElementById('statCache');
const statBlocked = document.getElementById('statBlocked');
const statSpeed = document.getElementById('statSpeed');
const statUptime = document.getElementById('statUptime');

// ---------- Helpers ----------
function addLog(msg, level = 'info') {
const color = level === 'error' ? '#ef4444' : level === 'warn' ? '#f59e0b' : level === 'success' ? '#22c55e' : '#94a3b8';
const time = new Date().toLocaleTimeString();
const entry = document.createElement('div');
entry.className = 'log-entry';
entry.style.color = color;
entry.textContent = `[${time}][${level.toUpperCase()}] ${msg}`;
logsContainer.appendChild(entry);
logsContainer.scrollTop = logsContainer.scrollHeight;
if (logsContainer.children.length > 100) logsContainer.removeChild(logsContainer.firstChild);
}

function updateStats() {
statRequests.textContent = state.requests;
statCache.textContent = state.cacheHits;
statBlocked.textContent = state.blocked;
statSpeed.textContent = state.avgTime + 'ms';
statUptime.textContent = state.uptime + '%';
}

function isValidURL(s) {
try { const u = new URL(s); return u.protocol === 'http:' || u.protocol === 'https:'; }
catch { return false; }
}

// Build proxy URL using selected API
function buildProxyUrl(target) {
const api = settings.proxyApi;
let base = '';
if (api === 'allorigins') base = 'https://api.allorigins.win/raw?url=';
else if (api === 'corsproxy') base = 'https://corsproxy.io/?' + encodeURIComponent(target);
else if (api === 'thingproxy') base = 'https://thingproxy.freeboard.io/fetch/' + encodeURIComponent(target);
else base = `https://api.allorigins.win/raw?url=`;
return base + encodeURIComponent(target);
}

// Rewrite links
function rewriteHtml(html, baseUrl) {
// Remove frame-busting
html = html.replace(/<script[^>]*>.*?window\.top\.location.*?<\/script>/gis, '');
html = html.replace(/<meta[^>]*http-equiv=["']refresh["'][^>]*>/gi, '');

html = html.replace(/(src|href|action)=(["'])((?:https?:)?\/\/[^"'\s]+|(?:\/[^"'\s]*))\2/gi, (match, attr, quote, url) => {
let absolute;
try { absolute = new URL(url, baseUrl).href; } catch { return match; }
if (settings.weeblyOnly) {
const host = new URL(absolute).hostname;
if (!host.endsWith('.weebly.com') && host !== 'weebly.com') return match;
}
const proxied = buildProxyUrl(absolute);
return `${attr}=${quote}${proxied}${quote}`;
});

html = html.replace(/<form\s/gi, '<form target="_blank" ');
return html;
}

// ---------- Core proxy function ----------
async function loadProxy(target) {
// Rate limit
const now = Date.now();
state.timestamps = state.timestamps.filter(t => now - t < 60000);
if (state.timestamps.length >= settings.rateLimit) {
feedback.textContent = '⚠ Rate limit exceeded. Wait a moment.';
feedback.className = 'error';
state.blocked++;
updateStats();
addLog(`Rate limit blocked: ${target}`, 'warn');
loadingOverlay.style.display = 'none';
return;
}
state.timestamps.push(now);

// Cache
const cached = cache.get(target);
if (cached && (now - cached.time < settings.cacheTtl * 1000)) {
state.cacheHits++;
updateStats();
addLog(`Cache hit: ${target}`, 'success');
const blob = new Blob([cached.html], { type: 'text/html' });
iframe.src = URL.createObjectURL(blob);
loadingOverlay.style.display = 'none';
feedback.textContent = 'Loaded from cache ✓';
feedback.className = 'valid';
return;
}

loadingOverlay.style.display = 'flex';
feedback.textContent = 'Fetching …';
feedback.className = 'info';
const startTime = performance.now();

try {
const proxyUrl = buildProxyUrl(target);
const resp = await fetch(proxyUrl);
if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
let html = await resp.text();
const contentType = resp.headers.get('content-type') || '';
if (contentType.includes('text/html')) {
html = rewriteHtml(html, target);
}

cache.set(target, { html, time: Date.now() });

const blob = new Blob([html], { type: 'text/html' });
iframe.src = URL.createObjectURL(blob);

const elapsed = Math.round(performance.now() - startTime);
state.totalTime += elapsed;
state.requests++;
state.avgTime = state.requests ? Math.round(state.totalTime / state.requests) : 0;
updateStats();
addLog(`Loaded: ${target} (${elapsed}ms)`, 'success');
feedback.textContent = `Loaded in ${elapsed}ms ✓`;
feedback.className = 'valid';
} catch (err) {
feedback.textContent = `✗ Failed: ${err.message}`;
feedback.className = 'error';
addLog(`Error loading ${target}: ${err.message}`, 'error');
state.blocked++;
updateStats();
// Try fallback proxy automatically
if (settings.proxyApi !== 'thingproxy') {
const fallback = settings.proxyApi === 'allorigins' ? 'corsproxy' : 'thingproxy';
addLog(`Trying fallback proxy: ${fallback}`, 'warn');
settings.proxyApi = fallback;
// retry once
setTimeout(() => loadProxy(target), 300);
}
} finally {
loadingOverlay.style.display = 'none';
}
}

// ---------- UI events ----------
urlInput.addEventListener('input', () => {
const val = urlInput.value.trim();
if (!val) {
feedback.textContent = '';
urlInput.classList.remove('valid', 'invalid');
goBtn.disabled = true;
return;
}
if (isValidURL(val)) {
feedback.textContent = '✓ Valid URL';
feedback.className = 'valid';
urlInput.classList.add('valid'); urlInput.classList.remove('invalid');
goBtn.disabled = false;
} else {
feedback.textContent = '✗ Invalid URL (needs http:// or https://)';
feedback.className = 'error';
urlInput.classList.add('invalid'); urlInput.classList.remove('valid');
goBtn.disabled = true;
}
});

goBtn.addEventListener('click', () => {
const target = urlInput.value.trim();
if (!isValidURL(target)) return;
iframe.src = 'about:blank';
setTimeout(() => loadProxy(target), 100);
});

urlInput.addEventListener('keydown', e => { if (e.key === 'Enter') goBtn.click(); });

// Advanced panel toggle
toggleAdvanced.addEventListener('change', () => {
advancedPanel.classList.toggle('show', toggleAdvanced.checked);
});

// Settings
document.getElementById('applySettings').addEventListener('click', () => {
settings.rateLimit = parseInt(document.getElementById('rateLimit').value) || 20;
settings.cacheTtl = parseInt(document.getElementById('cacheTtl').value) || 30;
settings.userAgent = document.getElementById('userAgent').value;
settings.weeblyOnly = document.getElementById('weeblyOnly').value === 'yes';
settings.proxyApi = document.getElementById('proxyApi').value;
addLog(`Settings updated: rate=${settings.rateLimit}, cache=${settings.cacheTtl}s, weeblyOnly=${settings.weeblyOnly}, proxy=${settings.proxyApi}`, 'warn');
});

document.getElementById('clearCache').addEventListener('click', () => {
cache.clear();
addLog('Cache cleared', 'warn');
});

// Download current page (HTML from iframe)
document.getElementById('downloadPage').addEventListener('click', () => {
const lastUrl = urlInput.value.trim();
if (!lastUrl) { addLog('No page loaded yet', 'error'); return; }
const cached = cache.get(lastUrl);
if (!cached) { addLog('Page not in cache, reload first', 'error'); return; }
const blob = new Blob([cached.html], { type: 'text/html' });
const a = document.createElement('a');
a.href = URL.createObjectURL(blob);
a.download = 'proxied-page.html';
a.click();
URL.revokeObjectURL(a.href);
addLog('Page downloaded', 'success');
});

// Initialize: Load Google on startup (but show about:blank first, then proxy)
iframe.src = 'about:blank';
const defaultUrl = 'https://google.com';
urlInput.value = defaultUrl;
addLog('StrongGuardian+ ready – loading Google by default', 'info');
setTimeout(() => loadProxy(defaultUrl), 300);
</script>
</body>
</html>
